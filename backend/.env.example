ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Best tier below Fable 5: Opus 4.8. Faster/cheaper: claude-sonnet-5
ANTHROPIC_MODEL=claude-opus-4-8
# Used for picks, portfolio, synopsis, explore (~2-3x faster than Opus)
ANTHROPIC_MODEL_FAST=claude-sonnet-5
# Optional: faster morning brief (empty = ANTHROPIC_MODEL). Sonnet ~2-3x faster, slightly less depth.
# ANTHROPIC_MODEL_BRIEF=claude-sonnet-5
FMP_API_KEY=
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8742
DATABASE_PATH=./data/market_morning.db
MOCK_MODE=0

# SaaS / hosted standalone app (see docs/SUBSCRIPTIONS.md)
SAAS_MODE=0
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
AUTH_PASSWORD_SALT=change-me-in-production
WEB_APP_URL=http://localhost:8742/app
CORS_ORIGINS=http://localhost:8742,http://127.0.0.1:8742,http://localhost:3000

# Stripe (test mode) — create Products/prices in Dashboard
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_DESK_MONTHLY=
STRIPE_PRICE_DESK_YEARLY=

# Robinhood sync (optional — extension syncs on open when configured)
# Option A: local MCP bridge (recommended — run scripts/robinhood-mcp-bridge.py)
ROBINHOOD_SYNC_PROXY_URL=http://127.0.0.1:8743
# Option B: direct MCP bearer token (if you have one)
# ROBINHOOD_MCP_ACCESS_TOKEN=
# ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
# Override default account (otherwise uses is_default from get_accounts)
# ROBINHOOD_ACCOUNT_NUMBER=858036189
# Min seconds between syncs (default 300 = 5 min)
# ROBINHOOD_SYNC_COOLDOWN_SECONDS=300
